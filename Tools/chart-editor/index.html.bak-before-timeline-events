<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>4K Speed-Coef Chart Editor v5</title>
<style>
:root{--bg:#0b0c11;--panel:#171a23;--panel2:#222635;--line:#3b4257;--text:#edf0f7;--muted:#9fa8bd;--accent:#86d7ff;--c1:#79e69b;--c0:#ffd267;--danger:#ff6b7a;--cursor:#ff7aa8;--select:#a78bfa;--wave:#72d7ff}*{box-sizing:border-box}body{margin:0;height:100vh;overflow:hidden;background:var(--bg);color:var(--text);font-family:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}button,input,select,textarea{font:inherit;color:var(--text);background:var(--panel2);border:1px solid var(--line);border-radius:10px;padding:7px 9px}button{cursor:pointer;user-select:none}button:hover{border-color:var(--accent)}button.active{border-color:var(--accent);background:#26364b}button.danger:hover{border-color:var(--danger)}button:disabled{opacity:.45;cursor:default}label{color:var(--muted);font-size:12px;display:flex;align-items:center;gap:6px;white-space:nowrap}input[type=number]{width:86px}input[type=text]{width:160px}input[type=range]{width:106px}textarea{width:100%;min-height:56px;resize:vertical}.app{height:100vh;display:grid;grid-template-rows:auto 1fr auto}.topbar{display:flex;flex-wrap:wrap;gap:8px;align-items:center;padding:9px 10px;background:var(--panel);border-bottom:1px solid var(--line)}.group{display:flex;gap:6px;align-items:center;padding-right:9px;border-right:1px solid var(--line)}.group:last-child{border-right:none}.main{min-height:0;display:grid;grid-template-columns:1fr 386px}.canvas-wrap{position:relative;overflow:hidden;background:#090b10;min-width:0}canvas{display:block;width:100%;height:100%;cursor:crosshair}.help{display:none}.side{background:var(--panel);border-left:1px solid var(--line);overflow:auto;padding:11px}.card{border:1px solid var(--line);background:rgba(255,255,255,.025);border-radius:14px;padding:11px;margin-bottom:11px}.card h3{margin:0 0 10px;font-size:14px}.row{display:flex;gap:7px;align-items:center;flex-wrap:wrap;margin-bottom:8px}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px}.grid2 label,.stack label,.stack{align-items:flex-start;flex-direction:column;gap:4px}.grid2 input,.stack input,.stack select{width:100%}.cover{width:74px;height:74px;border-radius:12px;border:1px solid var(--line);background:var(--panel2);object-fit:cover}.mono{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px;color:var(--muted)}.small{font-size:12px;color:var(--muted);line-height:1.45}.hidden{display:none}.note-list{max-height:205px;overflow:auto;border:1px solid var(--line);border-radius:10px}.note-item{display:grid;grid-template-columns:56px 38px 50px 1fr;gap:6px;padding:6px 8px;border-bottom:1px solid rgba(255,255,255,.06);font-size:12px;cursor:pointer}.note-item:hover{background:rgba(134,215,255,.08)}.note-item.selected{background:rgba(167,139,250,.18)}.statusbar{display:flex;gap:18px;align-items:center;white-space:nowrap;padding:6px 12px;background:var(--panel);border-top:1px solid var(--line);color:var(--muted);font-size:12px}.project-group select{max-width:170px}.project-group .mono{max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
</style>
</head>
<body>
<div class="app">
<div class="topbar">
<div class="group project-group">
  <button id="projectRefreshBtn">Refresh</button>
  <button id="projectNewSongBtn">New Song</button>
  <button id="projectNewChartBtn">New Chart</button>
  <label>Song <select id="projectSongSelect"><option value="">Songs...</option></select></label>
  <label>Chart <select id="projectChartSelect"><option value="">Charts...</option></select></label>
  <label>Audio <select id="projectAudioSelect"><option value="">Audio...</option></select></label>
  <button id="projectLoadBtn">Load</button>
  <button id="projectSaveBtn">Save Chart</button>
  <input id="projectNewSongAudioInput" class="hidden" type="file" accept="audio/*">
  <span id="projectStatus" class="mono">project: local</span>
</div>
<div class="group"><button id="playBtn">Play</button><button id="stopBtn">Stop</button><button id="playFromViewBtn">From View</button><button id="previewBtn">Preview</button><label><input id="loopToggle" type="checkbox">Loop</label></div>
<div class="group"><label>Music <input id="audioFile" type="file" accept="audio/*"></label><label>Cover <input id="coverFile" type="file" accept="image/*"></label><label>Music <input id="musicVolume" type="range" min="0" max="1" step="0.01" value="0.8"></label><label>Hit <input id="hitVolume" type="range" min="0" max="1" step="0.01" value="0.65"></label>
      <label>Rate <input id="playbackRate" type="range" min="1" max="2" step="0.01" value="1"></label>
      <span id="playbackRateLabel" class="mono">1.00x</span><label>Wave <input id="waveGain" type="range" min="1" max="10" step="0.1" value="5.0"></label></div>
<div class="group"><label>BPM <input id="bpmInput" type="number" value="180" min="1" step="0.01"></label><label>Offset <input id="offsetInput" type="number" value="0" step="1"></label><label>Snap <select id="snapInput"><option value="1">1/1</option><option value="2">1/2</option><option value="3">1/3</option><option value="4" selected>1/4</option><option value="6">1/6</option><option value="8">1/8</option><option value="12">1/12</option><option value="16">1/16</option><option value="24">1/24</option><option value="32">1/32</option></select></label><label>Zoom <input id="zoomInput" type="range" min="45" max="2000" step="1" value="160"></label></div>
<div class="group"><button id="toolPlaceBtn" class="active">Place [N]</button><button id="toolSelectBtn">Select [S]</button><button id="toolPlayBtn">Playhead [P]</button></div>
<div class="group"><button id="coef1Btn" class="active">Coef 1</button><button id="coef0Btn">Coef 0</button><button id="tapModeBtn" class="active">Tap</button><button id="holdModeBtn">Hold</button><label><input id="recordToggle" type="checkbox">Record</label></div>
<div class="group"><button id="undoBtn">Undo</button><button id="redoBtn">Redo</button><button id="copyBtn">Copy</button><button id="pasteBtn">Paste</button><button id="mirrorBtn">Mirror</button></div>
</div>
<div class="main">
<div class="canvas-wrap"><canvas id="editorCanvas"></canvas><div class="help">Timeline goes bottom to top. The waveform is shown in the large left rail and behind lanes. Use Wave to amplify it.<br>Wheel: scroll. Ctrl/Alt+Wheel: zoom. Click: place/select. Ctrl/Shift+Click: multi-select. Drag empty: marquee. Drag selected: move.<br>1/0: coef. T/H: tap/hold. Del: delete. Ctrl+C/V/Z/Y. M: mirror. Space: play. D F J K = current coef input.</div></div>
<aside class="side">
<div class="card"><h3>Controls</h3><div class="small">
시간은 아래에서 위로 진행됩니다. 마우스 휠 방향을 반대로 수정했습니다.<br>
D/F/J/K는 4개 레인 입력이고, 현재 선택된 speedupCoef(1 또는 0)로 노트가 기록됩니다. coef별 별도 키는 없습니다.<br>
offset은 chart timeline 위에서 audio 0ms가 놓이는 위치입니다. 노란 점선이 AUDIO 0 위치입니다.
</div></div><div class="card"><h3>Song Metadata</h3><div class="row"><img id="coverPreview" class="cover" alt="cover"><div class="stack" style="flex:1;min-width:0"><label>Title <input id="metaTitle" type="text" value="Untitled"></label><label>Artist <input id="metaArtist" type="text"></label></div></div><div class="grid2"><label>Source / Album <input id="metaSource" type="text"></label><label>Mapper <input id="metaMapper" type="text"></label></div><div class="grid2"><label>Preview Start(ms) <input id="previewStartInput" type="number" value="0" step="10"></label><label>Preview End(ms) <input id="previewEndInput" type="number" value="15000" step="10"></label></div><label class="stack">Extra Info <textarea id="metaExtra"></textarea></label></div>
<div class="card"><h3>Difficulty</h3><div class="grid2"><label>Name <input id="diffName" type="text" value="Normal"></label><label>Level <input id="diffLevel" type="number" value="1" step="0.1"></label></div><div class="grid2"><label>Scroll <input id="diffScroll" type="number" value="1" step="0.05"></label><label>Base Speed <input id="diffBaseSpeed" type="number" value="1" step="0.01"></label></div><label class="stack">Difficulty Notes <textarea id="diffNotes"></textarea></label></div>
<div class="card"><h3>BPM / Snap Helper</h3><div class="row"><button id="jumpPrevMeasureBtn">Prev Bar</button><button id="jumpNextMeasureBtn">Next Bar</button><button id="jumpPrevBeatBtn">Prev Beat</button><button id="jumpNextBeatBtn">Next Beat</button></div><div class="row"><button id="jumpPrevSnapBtn">Prev Snap</button><button id="jumpNextSnapBtn">Next Snap</button><button id="snapPlayheadBtn">Snap Playhead</button></div><div class="mono" id="snapInfo">beat 333.33ms</div></div>
<div class="card"><h3>Chart</h3><div class="row"><button id="exportBtn">Save Chart</button><button id="importBtn">Import JSON</button><input id="importFile" class="hidden" type="file" accept="application/json,.json"><button id="clearBtn" class="danger">Clear</button></div><div class="row"><button id="sampleBtn">Sample Pattern</button><button id="quantizeBtn">Quantize Selected</button><button id="deleteSelectedBtn2" class="danger">Delete Selected</button></div><div class="mono" id="chartStats">notes: 0</div></div>
<div class="card"><h3>Auto Coef / Difficulty Curve</h3>
<div class="small">
노트 밀도를 Gaussian smoothing으로 분석해서 <code>coef 1</code> 노트에 곱할 최종 multiplier를 만듭니다.<br>
저장 시 <code>speedupCoef = baseSpeedupCoef × densityMultiplier × rampMultiplier × manualMultiplier</code> 형태로 기록됩니다.
다시 불러올 때는 <code>baseSpeedupCoef</code> 기준으로 에디터의 coef 0/1 상태를 복원합니다.
</div>
<div class="grid2"><label>Sigma(ms) <input id="autoSigmaInput" type="number" value="1600" min="100" step="100"></label><label>Step(ms) <input id="autoStepInput" type="number" value="100" min="25" step="25"></label></div>
<div class="grid2"><label>Density Min <input id="autoMinInput" type="number" value="0.2" min="0" step="0.05"></label><label>Density Max <input id="autoMaxInput" type="number" value="1" min="0" step="0.05"></label></div>
<div class="grid2"><label>Density Power <input id="autoPowerInput" type="number" value="1.15" min="0.1" step="0.05"></label><label>Output Cap <input id="autoCapInput" type="number" value="1.1" min="0.1" step="0.05"></label></div>
<div class="grid2"><label>Ramp Start <input id="autoRampStartInput" type="number" value="1" min="0" step="0.01"></label><label>Ramp End <input id="autoRampEndInput" type="number" value="1.05" min="0" step="0.01"></label></div>
<div class="grid2"><label>Ramp Power <input id="autoRampPowerInput" type="number" value="1.2" min="0.1" step="0.1"></label><label>Curve Axis Max <input id="autoAxisMaxInput" type="number" value="1.1" min="0.1" step="0.05"></label></div>
<label class="stack">Manual Anchors <textarea id="autoAnchorsInput" placeholder="선택 사항. timeMs,multiplier 예:&#10;0,1.0&#10;60000,0.95&#10;120000,1.08"></textarea></label>
<div class="row"><button id="autoGenerateBtn">Generate Curve</button><button id="autoExportBtn">Generate + Save Chart</button><label><input id="autoShowCurveToggle" type="checkbox" checked>Show Curve</label></div>
<div class="small">
<span style="color:#72d7ff">cyan</span>: density multiplier /
<span style="color:#ffd267">yellow</span>: global ramp /
<span style="color:#a78bfa">purple</span>: final multiplier
</div>
<div class="mono" id="autoCurveStats">curve: none</div></div>
<div class="card"><h3>Loop / Preview</h3><div class="row"><button id="setLoopStartBtn">Set Start</button><button id="setLoopEndBtn">Set End</button><button id="setPreviewStartBtn">Set Preview Start</button></div><div class="grid2"><label>Loop Start <input id="loopStartInput" type="number" value="0" step="10"></label><label>Loop End <input id="loopEndInput" type="number" value="8000" step="10"></label></div></div>
<div class="card"><h3>Selected Notes</h3><div id="selectedEmpty" class="small">No selected notes.</div><div id="selectedPanel" class="hidden"><div class="mono" id="selectedSummary">selected: 0</div><div class="grid2"><label>Time <input id="selTime" type="number" step="1"></label><label>Lane <input id="selLane" type="number" min="1" max="4" step="1"></label></div><div class="grid2"><label>Duration <input id="selDuration" type="number" min="0" step="1"></label><label>Speedup Coef <select id="selCoef"><option value="1">1</option><option value="0">0</option></select></label></div><div class="row"><button id="applySelectedBtn">Apply to First</button><button id="auditionSelectedBtn">Audition</button><button id="deleteSelectedBtn" class="danger">Delete</button></div></div></div>
<div class="card"><h3>Nearby Notes</h3><div class="note-list" id="noteList"></div></div>
<div class="card"><h3>Format</h3><div class="mono">note = { timeMs, lane: 0..3, speedupCoef: 0|1, durationMs }<br>durationMs = 0: tap. durationMs &gt; 0: hold.<br>Save Chart writes final float speedupCoef plus baseSpeedupCoef, density/ramp/manual multipliers, and autoSpeedupCoefMultiplier. Load restores editor coef buttons from baseSpeedupCoef.</div></div>
</aside>
</div>
<div class="statusbar"><span id="timeStatus">time 0 ms</span><span id="viewStatus">bottom 0 ms</span><span id="snapStatus">snap 83.33 ms</span><span id="modeStatus">Coef 1 / Tap</span><span id="selectStatus">selected 0</span><span id="audioStatus">audio: none / waveform: none</span></div>
</div>
<script>
(()=>{
const $=id=>document.getElementById(id),canvas=$('editorCanvas'),ctx=canvas.getContext('2d');
const lanes=4,chartKeys=['d','f','j','k'];
const state={notes:[],selectedIds:new Set(),clipboard:[],toolMode:'place',currentCoef:1,currentMode:'tap',playbackRate:1,bpm:180,snapDiv:4,offsetMs:0,pxPerSecond:160,viewStartMs:0,playheadMs:0,isPlaying:false,loop:false,loopStartMs:0,loopEndMs:8000,audioFileName:'',audioDurationMs:0,coverDataUrl:'',recordKeys:false,drag:null,meta:{title:'Untitled',artist:'',source:'',mapper:'',previewStartMs:0,previewEndMs:15000,extra:''},difficulty:{name:'Normal',level:1,scroll:1,baseSpeed:1,notes:''},project:{available:false,songs:[],songName:'',chartName:'',audioName:'',pendingNewSong:null},autoCoef:{curve:[],settings:{sigmaMs:1600,stepMs:100,minMultiplier:.2,maxMultiplier:1,densityPower:1.15,rampGain:.05,rampStartMultiplier:1,rampEndMultiplier:1.05,rampPower:1.2,cap:1.1,axisMax:1.1,showCurve:true,anchors:''}}};
let audioCtx=null,audioBuffer=null,waveformPeaks=null,nextId=1,lastFrame=performance.now(),playbackStartPerf=0,playbackStartChartMs=0,audioStartedForThisPlayback=false,bgmSource=null,bgmGain=null,bgmActive=false,bgmStartedChartMs=0,bgmStartedCtxTime=0,bgmAudioOffsetSec=0;
const history={undo:[],redo:[],max:150};
function ensureAudioCtx(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();if(audioCtx.state==='suspended')audioCtx.resume();}
function snapshot(){return JSON.stringify({notes:state.notes.map(n=>({...n})),meta:{...state.meta},difficulty:{...state.difficulty},bpm:state.bpm,snapDiv:state.snapDiv,offsetMs:state.offsetMs,loopStartMs:state.loopStartMs,loopEndMs:state.loopEndMs,coverDataUrl:state.coverDataUrl,autoCoef:{settings:{...state.autoCoef.settings},curve:state.autoCoef.curve||[]}});}
function restore(s){const d=JSON.parse(s);state.notes=(d.notes||[]).map(n=>({...n}));state.meta={...state.meta,...(d.meta||{})};state.difficulty={...state.difficulty,...(d.difficulty||{})};state.bpm=d.bpm??state.bpm;state.snapDiv=d.snapDiv??state.snapDiv;state.offsetMs=d.offsetMs??state.offsetMs;state.loopStartMs=d.loopStartMs??state.loopStartMs;state.loopEndMs=d.loopEndMs??state.loopEndMs;state.coverDataUrl=d.coverDataUrl||'';if(d.autoCoef){state.autoCoef={...state.autoCoef,...d.autoCoef,settings:{...state.autoCoef.settings,...(d.autoCoef.settings||{})},curve:d.autoCoef.curve||[]};autoCoefSyncSettingsToUi();autoCoefUpdateStats()}nextId=Math.max(1,...state.notes.map(n=>n.id||0))+1;state.selectedIds.clear();syncStateToUi();updatePanels();}
function pushHistory(){history.undo.push(snapshot());if(history.undo.length>history.max)history.undo.shift();history.redo=[];updateUndoRedoButtons();}
function undo(){if(!history.undo.length)return;history.redo.push(snapshot());restore(history.undo.pop());updateUndoRedoButtons();}
function redo(){if(!history.redo.length)return;history.undo.push(snapshot());restore(history.redo.pop());updateUndoRedoButtons();}
function updateUndoRedoButtons(){$('undoBtn').disabled=!history.undo.length;$('redoBtn').disabled=!history.redo.length;}
function beatMs(){return 60000/Math.max(1,state.bpm)}function barMs(){return beatMs()*4}function snapMs(){return beatMs()/state.snapDiv}function snapTime(ms){return Math.round(ms/snapMs())*snapMs()}
function msToY(ms){const H=canvas._cssH||canvas.height;return H-((ms-state.viewStartMs)/1000)*state.pxPerSecond}function yToMs(y){const H=canvas._cssH||canvas.height;return state.viewStartMs+((H-y)/state.pxPerSecond)*1000}
function autoCoefCurveReserveEnabled(){return !!(state.autoCoef&&state.autoCoef.settings&&state.autoCoef.settings.showCurve)}
function laneArea(cssW=canvas._cssW||canvas.width){
 const left=116,outerRight=cssW-34,total=Math.max(260,outerRight-left);
 if(autoCoefCurveReserveEnabled()){
  const unit=total/(lanes+1.5);
  const width=unit*lanes;
  const right=left+width;
  const curveLeft=right+6;
  const curveRight=outerRight;
  return{left,right,width,laneW:unit,curveLeft,curveRight,curveWidth:Math.max(24,curveRight-curveLeft)};
 }
 const right=outerRight,width=right-left;
 return{left,right,width,laneW:width/lanes,curveLeft:right+6,curveRight:outerRight,curveWidth:Math.max(24,outerRight-(right+6))}
}
function xToLane(x){const a=laneArea();return Math.max(0,Math.min(lanes-1,Math.floor((x-a.left)/a.laneW)))}function laneToX(lane){const a=laneArea();return a.left+lane*a.laneW}function coefColor(c,a=1){return Number(c)===1?`rgba(121,230,155,${a})`:`rgba(255,210,103,${a})`}
function resize(){const r=canvas.parentElement.getBoundingClientRect(),dpr=window.devicePixelRatio||1;canvas.width=Math.max(300,Math.floor(r.width*dpr));canvas.height=Math.max(300,Math.floor(r.height*dpr));canvas._cssW=r.width;canvas._cssH=r.height;ctx.setTransform(dpr,0,0,dpr,0,0)}function clearCanvas(){const dpr=window.devicePixelRatio||1;ctx.setTransform(dpr,0,0,dpr,0,0);ctx.clearRect(0,0,canvas._cssW||canvas.width,canvas._cssH||canvas.height)}
function draw(){const W=canvas._cssW||canvas.width,H=canvas._cssH||canvas.height,a=laneArea(W);clearCanvas();ctx.fillStyle='#090b10';ctx.fillRect(0,0,W,H);drawWaveform(W,H,a);drawLanes(W,H,a);drawGrid(W,H,a);drawAudioOffsetMarker(W,a);drawLoopRegion(a);drawAutoCoefCurve(W,H,a);drawNotes(a);drawDragPreview(a);drawMarquee();drawPlayhead(W,a)}
function chartToAudioMs(chartMs){return chartMs-state.offsetMs}
function audioToChartMs(audioMs){return audioMs+state.offsetMs}
function wavePeakAt(tMs,gain){if(!waveformPeaks||!state.audioDurationMs)return 0;const audioMs=chartToAudioMs(tMs);if(audioMs<0||audioMs>state.audioDurationMs)return 0;const idx=Math.floor((audioMs/state.audioDurationMs)*waveformPeaks.length),p=waveformPeaks[Math.max(0,Math.min(waveformPeaks.length-1,idx))]||0;return Math.min(1,Math.pow(p*gain,.72))}
