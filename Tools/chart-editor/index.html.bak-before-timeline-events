async function projectLoadSelected(){
  const songName=projectSelectedSongName();
  const chartName=projectSelectedChartName();
  if(!songName||!chartName){
    alert('Song과 Chart를 선택하세요.');
    return;
  }
  try{
    projectSetStatus('project: loading chart...');
    const song=projectSongByName(songName);
    const url=`/api/chart?song=${encodeURIComponent(songName)}&chart=${encodeURIComponent(chartName)}`;
    const data=await projectFetchJson(url);
    pushHistory();
    const dropped=projectImportChartData(data);
    state.project.songName=songName;
    state.project.chartName=chartName;

    const audioFiles=(song&&song.audio)||[];
    const chartAudio=data.meta&&data.meta.audioFileName?data.meta.audioFileName:'';
    const selectedAudio=projectSelectedAudioName();
    const preferredAudio=(chartAudio&&audioFiles.includes(chartAudio))?chartAudio:(selectedAudio&&audioFiles.includes(selectedAudio))?selectedAudio:audioFiles[0];
    if(preferredAudio){
      await projectLoadAudioForSong(songName,preferredAudio);
      state.meta.audioFileName=preferredAudio;
    }else{
      state.audioFileName='';
      state.audioDurationMs=0;
      waveformPeaks=null;
      projectSetStatus('loaded chart / no audio');
    }

    const coverFiles=(song&&song.covers)||[];
    const chartCover=data.meta&&data.meta.coverFileName?data.meta.coverFileName:'';
    const preferredCover=(chartCover&&coverFiles.includes(chartCover))?chartCover:coverFiles[0];
    if(preferredCover){
      state.coverDataUrl=`/api/media?song=${encodeURIComponent(songName)}&file=${encodeURIComponent(preferredCover)}`;
      $('coverPreview').src=state.coverDataUrl;
    }

    syncStateToUi();
    updatePanels();
    projectSetStatus(`loaded: ${songName}/${chartName}`);
    if(dropped>0)alert(`겹치는 노트 ${dropped}개를 제거하고 불러왔습니다.`);
  }catch(e){
    console.error(e);
    projectSetStatus('project: load failed');
    alert('Chart load failed: '+e.message);
  }
}
