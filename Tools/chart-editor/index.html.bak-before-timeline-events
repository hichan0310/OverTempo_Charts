function projectBuildPayload(){
  autoCoefGenerateCurve();
  const payload=projectBuildBasePayload();
  const st=autoCoefReadSettings();
  payload.autoCoef={
    schemaVersion:1,
    generatedAt:new Date().toISOString(),
    description:'Final speedupCoef = baseSpeedupCoef * autoSpeedupCoefMultiplier. Load restores editable coef 0/1 from baseSpeedupCoef.',
    settings:{...st},
    curve:state.autoCoef.curve.map(p=>({
      timeMs:p.timeMs,
      density01:+Number(p.density01||0).toFixed(6),
      difficulty01:+Number(p.difficulty01||0).toFixed(6),
      densityMultiplier:+Number(p.densityMultiplier||0).toFixed(6),
      rampMultiplier:+Number(p.rampMultiplier||1).toFixed(6),
      manualMultiplier:+Number(p.manualMultiplier||1).toFixed(6),
      finalUncapped:+Number(p.finalUncapped||p.multiplier||1).toFixed(6),
      multiplier:+Number(p.multiplier||1).toFixed(6)
    }))
  };
  payload.notes=state.notes.slice().sort((a,b)=>a.timeMs-b.timeMs||a.lane-b.lane).map(n=>{
    const base=Number(n.speedupCoef)>0?1:0;
    const point=base?autoCoefPointAt(n.timeMs):{densityMultiplier:0,rampMultiplier:0,manualMultiplier:0,finalUncapped:0,multiplier:0};
    const mult=base?Number(point.multiplier||0):0;
    return {
      timeMs:Math.round(n.timeMs),
      lane:n.lane,
      baseSpeedupCoef:base,
      densitySpeedupCoefMultiplier:+Number(point.densityMultiplier||0).toFixed(6),
      rampSpeedupCoefMultiplier:+Number(point.rampMultiplier||0).toFixed(6),
      manualSpeedupCoefMultiplier:+Number(point.manualMultiplier||0).toFixed(6),
      autoSpeedupCoefMultiplier:+mult.toFixed(6),
      speedupCoef:+(base*mult).toFixed(6),
      durationMs:Math.round(n.durationMs||0)
    };
  });
  return payload;
}
